{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NEXUS",
  "version": "0.1.0",
  "identifier": "com.nexus.agent",
  "build": {
    "beforeDevCommand": "cd ../nexus-web && npm run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NEXUS — Agent IA Souverain",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8081 ws://127.0.0.1:8081; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; script-src 'self' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "languages": ["French"]
      }
    }
  }
}
