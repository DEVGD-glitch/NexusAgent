# ═══════════════════════════════════════════════════════════════
# NEXUS — Configuration Template
# Copy this file to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════

# ── Environment ────────────────────────────────────────────────
NEXUS_ENV=development
NEXUS_LOG_LEVEL=INFO
NEXUS_SECRET_KEY=change-me-to-a-secure-random-string
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8080
NEXUS_WORKING_DIR=./nexus_data

# ── LLM Provider Keys ─────────────────────────────────────────
# Configure au moins UN provider pour que NEXUS fonctionne.
# Les providers "gratuits sans clé" (pollinations, g4f, deepinfra)
# sont actifs par défaut sans configuration.

# ── Gratuit (clé API gratuite, sans carte bancaire) ───────────
# Google Gemini (https://aistudio.google.com/app/apikey)
# Meilleur rapport qualité/prix, 1500 req/jour gratuites
# GOOGLE_API_KEY=AIza...

# Groq (https://console.groq.com/keys)
# Le plus rapide, 14400 req/jour gratuites
# GROQ_API_KEY=gsk_...

# OpenRouter (https://openrouter.ai/keys)
# 200+ modèles, 20+ modèles gratuits
# OPENROUTER_API_KEY=sk-or-...

# NVIDIA NIM (https://build.nvidia.com/)
# 100+ modèles gratuits, 40 req/min
# NVIDIA_API_KEY=nvapi-...

# Cerebras (https://cloud.cerebras.ai/)
# 1 million tokens/jour gratuits
# CEREBRAS_API_KEY=cerebras-...

# Together AI (https://api.together.xyz/settings/api-keys)
# Modèles open-source rapides
# TOGETHER_API_KEY=...

# ── Payant (facturation à l'usage) ─────────────────────────────
# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-...

# Anthropic (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=sk-ant-...

# ZAI / GLM (https://open.bigmodel.cn/)
# ZAI_API_KEY=...

# ── Gratuit (sans clé) ─────────────────────────────────────────
# Pollinations.ai — illimité, sans clé
POLLINATIONS_ENABLED=true

# G4F.dev — 200+ modèles, sans clé
G4F_ENABLED=true

# DeepInfra — modèles open-source
# DEEPINFRA_ENABLED=true

# ── Local ──────────────────────────────────────────────────────
# Ollama (https://ollama.com/download)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# ── LLM Router ────────────────────────────────────────────────
LLM_DEFAULT_PROVIDER=gemini
LLM_DEFAULT_MODEL=gemma-4-31b-it
LLM_FALLBACK_CHAIN=gemini,groq,openrouter,nvidia,cerebras,openai,anthropic

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./nexus_data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Security ──────────────────────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_DOCKER_IMAGE=nexus-sandbox:latest

# ── Avatar / Voice ────────────────────────────────────────────
VOICEVOX_HOST=http://127.0.0.1:50021
VOICEVOX_DEFAULT_SPEAKER=46
AIVIS_ENABLED=false
AIVIS_HOST=http://127.0.0.1:10101
# VRM_MODEL_PATH=./models/my_waifu.vrm

# ── Telegram Bot ──────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# ── Monitoring & Observability ────────────────────────────────
# Prometheus metrics endpoint
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# OpenTelemetry (optional, for distributed tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=nexus-agent

# ── Docker Sandbox (optional) ─────────────────────────────────
# Enable per-action Docker sandboxing for maximum security
# Requires Docker daemon running
PER_ACTION_SANDBOX_ENABLED=false
PER_ACTION_SANDBOX_IMAGE=nexus-sandbox:latest
PER_ACTION_SANDBOX_TIMEOUT=300

# ── Browser Automation (optional) ─────────────────────────────
# Requires browser-use Docker service
# See docker-compose.yml for setup
BROWSER_SERVICE_URL=http://localhost:8001
BROWSER_HEADLESS=true

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── File Upload Limits ────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=pdf,docx,xlsx,pptx,txt,md,py,js,ts,tsx,json,yaml,yml,csv

# ── Health Check Configuration ────────────────────────────────
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_SUBSYSTEMS=chromadb,llm,memory,docker

# ═══════════════════════════════════════════════════════════════
# QUICK START GUIDE
# ═══════════════════════════════════════════════════════════════
# 
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate a secure secret key:
#    python -c "import secrets; print(secrets.token_hex(32))"
#    Replace NEXUS_SECRET_KEY with the generated value
#
# 3. Choose your LLM provider:
#    - For FREE usage: Keep POLLINATIONS_ENABLED=true or G4F_ENABLED=true
#    - For BEST quality: Add GOOGLE_API_KEY or GROQ_API_KEY
#    - For LOCAL usage: Install Ollama and set OLLAMA_BASE_URL
#
# 4. Start the server:
#    cd NexusAgent
#    python -m nexus
#
# 5. Access the UI:
#    - Frontend: http://localhost:3000
#    - API Docs: http://localhost:8080/docs
#    - Health Check: http://localhost:8080/health
#
# ═══════════════════════════════════════════════════════════════
