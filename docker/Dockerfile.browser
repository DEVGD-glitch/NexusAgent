# ═══════════════════════════════════════════════════════════════
# NEXUS Browser Service — Dockerfile
# Isolated browser automation service with Playwright
# ═══════════════════════════════════════════════════════════════

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for Playwright
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gcc \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxkbcommon0 libxcomposite1 \
    libxdamage1 libxfixes3 libxrandr2 libgbm1 \
    libpango-1.0-0 libcairo2 libasound2 \
    && rm -rf /var/lib/apt/lists/*

# Install browser-use package
RUN pip install --no-cache-dir browser-use playwright
RUN playwright install --with-deps chromium

# Copy application
COPY . .

# Create non-root user
RUN useradd -m -u 1001 browser && chown -R browser:browser /app
USER browser

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

CMD ["python", "-m", "nexus.browser_service", "--port", "8001"]
